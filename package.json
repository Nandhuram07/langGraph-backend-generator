{
  "name": "ai-backend-generator",
  "version": "3.0.0",
  "description": "AI-powered backend scaffolder — generates full Express.js backends from user input",
  "type": "module",
  "main": "dist/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "next start",
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "mcp:dev": "tsx packages/mcp-server/src/index.ts",
    "mcp:build": "cd packages/mcp-server && npm run build",
    "mcp:install": "cd packages/mcp-server && npm install"
  },
  "dependencies": {
    "@langchain/core": "^1.1.33",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/langgraph-checkpoint-redis": "^1.0.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/archiver": "^7.0.0",
    "animate-presence": "^0.2.1",
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^12.38.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.3.7",
    "lucide-react": "^0.577.0",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "next": "^16.1.7",
    "ora": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "openai": "^4.0.0"
  }
}
